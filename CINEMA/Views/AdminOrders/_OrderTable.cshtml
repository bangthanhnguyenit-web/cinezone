@model IEnumerable<CINEMA.Models.Order>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-secondary text-center m-0 p-3">
        Không có dữ liệu để hiển thị.
    </div>
}
else
{
    <table class="table table-bordered table-hover text-center align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Mã đơn</th>
                <th>Khách hàng</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                string badgeClass = o.Status switch
                {
                    "Đã thanh toán" => "success",
                    "Đang chờ thanh toán" => "warning text-dark",
                    "Thanh toán thất bại" => "secondary",
                    "Đã hủy" => "danger",
                    _ => "light text-dark"
                };

                <tr>
                    <td><strong>@("CZ" + o.OrderId.ToString("D6"))</strong></td>
                    <td>@o.Customer?.FullName</td>
                    <td>@o.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-danger fw-bold">@String.Format("{0:N0} ₫", o.TotalAmount)</td>
                    <td><span class="badge bg-@badgeClass">@o.Status</span></td>
                    <td>
                        <a asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-info text-white">
                            <i class="bi bi-eye"></i> Xem
                        </a>
                        <form asp-action="Delete" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@o.OrderId" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa đơn này?');">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
