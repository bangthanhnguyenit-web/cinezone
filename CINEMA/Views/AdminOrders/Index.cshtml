@model IEnumerable<CINEMA.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_AdminLayout";

    var pending = Model.Where(o => o.Status == "Đang chờ thanh toán");
    var paid = Model.Where(o => o.Status == "Đã thanh toán");
    var failed = Model.Where(o => o.Status == "Thanh toán thất bại" || o.Status == "Đã hủy");
}

<div class="container mt-4">
    <h2 class="fw-bold text-center mb-4 text-gradient">📦 Quản lý đơn hàng</h2>

    <!-- ========== KHUNG 1: ĐÃ THANH TOÁN ========== -->
    
    <div class="card shadow mb-5">
        <div class="card-header bg-success text-white fw-bold">
            ✔️ Đơn đã thanh toán
        </div>
        <div class="card-body p-0">
            @await Html.PartialAsync("_OrderTable", paid)
        </div>
    </div>
    <!-- ========== KHUNG 2: ĐANG CHỜ ========== -->
    <div class="card shadow mb-5">
        <div class="card-header bg-warning text-dark fw-bold">
            ⏳ Đơn đang chờ thanh toán
        </div>
        <div class="card-body p-0">
            @await Html.PartialAsync("_OrderTable", pending)
        </div>
    </div>

    

    <!-- ========== KHUNG 3: THẤT BẠI / HỦY ========== -->
    <div class="card shadow mb-5">
        <div class="card-header bg-danger text-white fw-bold">
            ❌ Đơn thất bại hoặc đã hủy
        </div>
        <div class="card-body p-0">
            @await Html.PartialAsync("_OrderTable", failed)
        </div>
    </div>
</div>

<style>
    .text-gradient {
        background: linear-gradient(90deg, #007bff, #6610f2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>
