@model CINEMA.ViewModels.RevenueDashboardViewModel
@{
    ViewData["Title"] = "Thống kê doanh thu";
    Layout = "_AdminLayout";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-4 text-center text-gradient">📊 Thống kê doanh thu</h2>

    <!-- ================= FILTER ================= -->
    <form method="get" class="row g-3 mb-4 justify-content-center">
        <div class="col-md-3">
            <label class="form-label fw-semibold">Từ ngày</label>
            <input type="date" name="from" class="form-control"
                   value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold">Đến ngày</label>
            <input type="date" name="to" class="form-control"
                   value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100 fw-semibold">Lọc</button>
        </div>
    </form>

    <!-- ================= DASHBOARD ================= -->
    <div class="row mb-3 justify-content-center">
        <div class="col-md-6">
            <div class="card-box">
                <div class="label">📅 Khoảng lọc</div>
                <div class="sub fw-semibold">
                    @if (Model.FromDate.HasValue || Model.ToDate.HasValue)
                    {
                        <span>@Model.FromDate?.ToString("dd/MM/yyyy") - @Model.ToDate?.ToString("dd/MM/yyyy")</span>
                    }
                    else
                    {
                        <span>Toàn thời gian</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <!-- NAVBAR THỐNG KÊ -->
    <ul class="nav nav-pills justify-content-center mb-4 dashboard-nav">

        <li class="nav-item">
            <a class="nav-link active"
               data-bs-toggle="tab"
               href="#tongquan">
                📈 Tổng Quan
            </a>
        </li>



        <li class="nav-item">
            <a class="nav-link"
               data-bs-toggle="tab"
               href="#phim">
                🎬 Theo Phim
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               data-bs-toggle="tab"
               href="#suatchieu">
                🎬 Suất Chiếu
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link"
               data-bs-toggle="tab"
               href="#combo">
                🥤 Combo
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link"
               data-bs-toggle="tab"
               href="#chitiet">
                📋 Chi Tiết
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               data-bs-toggle="tab"
               href="#voucher">
                🎟 Voucher
            </a>
        </li>
    <div class="tab-content">

        <!-- ================= TỔNG QUAN ================= -->
        <div class="tab-pane fade show active" id="tongquan">

            <!-- Card doanh thu -->
            <div class="row g-3 mb-4 justify-content-center">
                <div class="col-md-3">
                    <div class="card-box">
                        <div class="label">Hôm nay</div>
                        <div class="value text-success">
                            @Model.TodayRevenue.ToString("N0") ₫
                        </div>
                        <div class="sub">
                            @Model.TodayTickets vé
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card-box">
                        <div class="label">Tháng</div>
                        <div class="value text-success">
                            @Model.MonthRevenue.ToString("N0") ₫
                        </div>
                        <div class="sub">
                            @Model.MonthTickets vé
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card-box">
                        <div class="label">Tổng</div>
                        <div class="value text-danger">
                            @Model.TotalRevenue.ToString("N0") ₫
                        </div>
                        <div class="sub">
                            @Model.TotalTickets vé
                        </div>
                    </div>
                </div>

            </div>

            <!-- Card trạng thái đơn -->
            <div class="row g-3 mb-4 justify-content-center">

                <div class="col-md-2">
                    <div class="card-box border-success">
                        <div class="label">Đã thanh toán</div>
                        <div class="value text-success">
                            @Model.PaidOrders
                        </div>
                    </div>
                </div>

                <div class="col-md-2">
                    <div class="card-box border-warning">
                        <div class="label">Đang chờ</div>
                        <div class="value text-warning">
                            @Model.PendingOrders
                        </div>
                    </div>
                </div>

                <div class="col-md-2">
                    <div class="card-box border-danger">
                        <div class="label">Đã hủy</div>
                        <div class="value text-danger">
                            @Model.CancelledOrders
                        </div>
                    </div>
                </div>

            </div>

            <!-- Biểu đồ -->
            <div class="row g-4">

                <div class="col-md-8">
                    <div class="chart-box">
                        <h5>📅 Doanh thu theo ngày</h5>
                        <canvas id="revenueByDateChart"></canvas>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="chart-box">
                        <h5>🎬 Top phim</h5>
                        <canvas id="revenueByMovieChart"></canvas>
                    </div>
                </div>

            </div>

            <div class="row g-4 mt-4">

                <div class="col-md-6">
                    <div class="chart-box">
                        <h5>📆 Theo tháng</h5>
                        <canvas id="revenueByMonthChart"></canvas>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="chart-box">
                        <h5>📊 Theo năm</h5>
                        <canvas id="revenueByYearChart"></canvas>
                    </div>
                </div>

            </div>

        </div>

        <!-- ================= DOANH THU VÉ ================= -->
        <div class="tab-pane fade" id="ve">

            <div class="chart-box">
                <h5>📅 Doanh thu theo ngày</h5>
                <canvas id="revenueByDateChart"></canvas>
            </div>

            <div class="row g-4 mt-4">

                <div class="col-md-6">
                    <div class="chart-box">
                        <h5>📆 Theo tháng</h5>
                        <canvas id="revenueByMonthChart"></canvas>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="chart-box">
                        <h5>📊 Theo năm</h5>
                        <canvas id="revenueByYearChart"></canvas>
                    </div>
                </div>

            </div>
        </div>

        <!-- ================= THEO PHIM ================= -->
        <div class="tab-pane fade" id="phim">
            <div class="chart-box">
                <h5>🎬 Top phim doanh thu</h5>
                <div class="row g-3 mb-4 justify-content-center">
                    <div class="col-md-3">
                        <div class="card-box border-info">
                            <div class="label">Đang chiếu / Sắp chiếu</div>
                            <div class="value text-info">@Model.NowShowingCount / @Model.ComingSoonCount</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card-box border-primary">
                            <div class="label">Top bán chạy nhất</div>
                            <div class="value text-primary" style="font-size:16px">@Model.TopSellingMovie</div>
                            <div class="sub">@Model.TopSellingTickets vé</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card-box border-danger">
                            <div class="label">Bán ít nhất</div>
                            <div class="value text-danger" style="font-size:14px">@Model.LeastSellingMovie</div>
                            <div class="sub">@Model.LeastSellingTickets vé</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card-box border-secondary">
                            <div class="label">Top doanh thu</div>
                            <div class="value text-secondary" style="font-size:16px">@Model.TopRevenueMovie</div>
                            <div class="sub">@Model.TopRevenueAmount.ToString("N0") ₫</div>
                        </div>
                    </div>
                    <div class="row g-3 mb-4 justify-content-center">
                        <div class="col-md-3"><div class="card-box border-primary"><div class="label">AOV Hôm nay</div><div class="value text-primary">@Model.AvgOrderValueToday.ToString("N0") ₫</div></div></div>
                        <div class="col-md-3"><div class="card-box border-primary"><div class="label">AOV Tháng này</div><div class="value text-primary">@Model.AvgOrderValueMonth.ToString("N0") ₫</div></div></div>
                        <div class="col-md-3"><div class="card-box border-primary"><div class="label">AOV Quý này</div><div class="value text-primary">@Model.AvgOrderValueQuarter.ToString("N0") ₫</div></div></div>
                        <div class="col-md-3"><div class="card-box border-primary"><div class="label">AOV Năm nay</div><div class="value text-primary">@Model.AvgOrderValueYear.ToString("N0") ₫</div></div></div>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="chart-box">
                                <h5>📊 So sánh doanh thu theo Phim</h5>
                                <canvas id="movieRevenueChart"></canvas>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="chart-box">
                                <h5>🎟️ So sánh số vé đã bán</h5>
                                <canvas id="ticketComparisonChart"></canvas>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="chart-box">
                                <h5>💰 Biểu đồ so sánh giá trị đơn (AOV)</h5>
                                <div class="chart-container" style="height: 300px;"><canvas id="aovChart"></canvas></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="chart-box">
                                <h5>📊 So sánh doanh thu 2 tháng gần nhất</h5>
                                <div class="chart-container" style="height: 300px;"><canvas id="monthCompareChart"></canvas></div>
                            </div>
                        </div>
                    </div>
                </div>
                <canvas id="revenueByMovieChart"></canvas>
            </div>
        </div>

        <div class="tab-pane fade" id="suatchieu">

            <div class="chart-box">

                <h5>🎬 Doanh thu theo suất chiếu</h5>

                <canvas id="showtimeRevenueChart"></canvas>

            </div>

            <div class="chart-box mt-4">

                <table class="table table-striped table-hover">

                    <thead class="table-dark">
                        <tr>
                            <th>Mã SC</th>
                            <th>Phim</th>
                            <th>Thời gian</th>
                            <th>Vé bán</th>
                            <th>Doanh thu</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.ShowtimeStatistics)
                        {
                            <tr>

                                <td>#@item.ShowtimeId</td>

                                <td>@item.MovieName</td>

                                <td>
                                    @item.StartTime.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td>@item.TicketCount</td>

                                <td class="fw-bold text-success">
                                    @item.Revenue.ToString("N0") ₫
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

        <!-- COMBO -->
        <div class="tab-pane fade" id="combo">

            <!-- GIỮ NGUYÊN TOÀN BỘ PHẦN COMBO CỦA BẠN -->

            <h4 class="text-center mb-4">
                🥤 THỐNG KÊ COMBO BẮP NƯỚC
            </h4>

            <div class="row text-center mb-4">
                <!-- ================= KPI CARDS ================= -->
                <div class="row g-3 mt-2">

                    <!-- ================= CARD 1 ================= -->
                    <div class="col-md-4">
                        <div class="kpi-card revenue">
                            <div class="kpi-header">
                                <span>💰 Doanh Thu Combo</span>
                            </div>

                            <div class="kpi-value text-success">
                                @Model.ComboRevenue.ToString("N0") ₫
                            </div>
                        </div>
                    </div>

                    <!-- ================= CARD 2 ================= -->
                    <div class="col-md-4">
                        <div class="kpi-card sold">
                            <div class="kpi-header">
                                <span>📦 Đã Bán</span>
                            </div>

                            <div class="kpi-value text-primary">
                                @Model.ComboSold
                            </div>
                        </div>
                    </div>

                    <!-- ================= CARD 3 ================= -->
                    <div class="col-md-4">
                        <div class="kpi-card best">
                            <div class="kpi-header">
                                <span>🔥 Bán Chạy Nhất</span>
                            </div>

                            <div class="kpi-value text-danger">
                                @Model.BestSellingCombo
                            </div>

                            <small class="text-muted">
                                @Model.BestSellingQuantity lượt bán
                            </small>
                        </div>
                    </div>

                    <!-- ================= WORST COMBO (FULL WIDTH) ================= -->
                    <div class="col-md-12">
                        <div class="kpi-alert">

                            <div>
                                <h5>⚠️ Combo cần cải thiện</h5>
                                <h4 class="mb-0">@Model.WorstSellingCombo</h4>
                                <small class="text-muted">Doanh số thấp nhất</small>
                            </div>

                            <div class="kpi-badge">
                                @Model.WorstSellingQuantity
                            </div>

                        </div>
                    </div>

                    <!-- ================= KPI 4 ================= -->
                    <div class="col-md-4">
                        <div class="kpi-card soft blue">
                            <div class="kpi-header">
                                📦 Tỷ lệ đơn có combo
                            </div>

                            <div class="kpi-value text-primary">
                                @Model.ComboAttachRate %
                            </div>
                        </div>
                    </div>

                    <!-- ================= KPI 5 ================= -->
                    <div class="col-md-4">
                        <div class="kpi-card soft green">
                            <div class="kpi-header">
                                💰 Tỷ trọng doanh thu combo
                            </div>

                            <div class="kpi-value text-success">
                                @Model.ComboRevenueRate %
                            </div>
                        </div>
                    </div>

                    <!-- ================= KPI 6 ================= -->
                    <div class="col-md-4">
                        <div class="kpi-card soft yellow">
                            <div class="kpi-header">
                                🧾 Chi tiêu / đơn
                            </div>

                            <div class="kpi-value text-warning">
                                @Model.AverageComboPerOrder.ToString("N0") ₫
                            </div>
                        </div>
                    </div>

                </div>

                <!-- ================= COMBO SECTION ================= -->
                <div class="row g-4 mt-2">

                    <!-- TOP BÁN CHẠY -->
                    <div class="col-md-4">
                        <div class="chart-card chart-blue">
                            <h5>🔥 Top 5 combo bán chạy</h5>
                            <canvas id="topComboChart"></canvas>
                        </div>
                    </div>

                    <!-- TOP DOANH THU -->
                    <div class="col-md-4">
                        <div class="chart-card chart-green">
                            <h5>💰 Top 5 doanh thu</h5>
                            <canvas id="topRevenueComboChart"></canvas>
                        </div>
                    </div>

                    <!-- THEO THÁNG -->
                    <div class="col-md-4">
                        <div class="chart-card chart-orange">
                            <h5>📊 Combo theo tháng</h5>
                            <canvas id="comboByMonthChart"></canvas>
                        </div>
                    </div>

                </div>


                <div class="row g-4 mt-4">

                    <!-- PIE -->
                    <div class="col-md-5">
                        <div class="chart-card chart-purple">
                            <h5>🥧 Tỷ lệ combo</h5>
                            <canvas id="comboPieChart"></canvas>
                        </div>
                    </div>

                    <!-- TABLE -->
                    <div class="col-md-7">
                        <div class="table-card">

                            <h5 class="mb-3">📋 Thống kê chi tiết combo</h5>

                            <div class="table-responsive">
                                <table class="table table-hover table-bordered align-middle">

                                    <thead class="table-dark">
                                        <tr>
                                            <th>Combo</th>
                                            <th>Số lượng</th>
                                            <th>Doanh thu</th>
                                            <th>%</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        @foreach (var combo in Model.ComboStatistics)
                                        {
                                            <tr>
                                                <td><b>@combo.ComboName</b></td>
                                                <td>@combo.QuantitySold</td>
                                                <td class="text-success fw-bold">
                                                    @combo.Revenue.ToString("N0") ₫
                                                </td>
                                                <td>
                                                    <span class="badge bg-primary fs-6">
                                                        @combo.Percentage %
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>

                                </table>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
        <!-- CHI TIẾT -->
        <div class="tab-pane fade" id="chitiet">

            <div class="chart-box">

                <h5>📋 Thống kê chi tiết Combo</h5>

                <table class="table table-striped table-hover">

                    <thead>
                        <tr>
                            <th>Tên Combo</th>
                            <th>Số lượng bán</th>
                            <th>Doanh thu</th>
                            <th>Tỷ lệ</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var combo in Model.ComboStatistics)
                        {
                            <tr>
                                <td>@combo.ComboName</td>
                                <td>@combo.QuantitySold</td>
                                <td>@combo.Revenue.ToString("N0") ₫</td>
                                <td>@combo.Percentage %</td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
        <div class="tab-pane fade" id="voucher">

            <div class="row g-3 mb-4">

                <div class="col-md-4">
                    <div class="card-box">
                        <div class="label">
                            Tổng giảm giá
                        </div>

                        <div class="value text-danger">
                            @Model.TotalDiscountAmount.ToString("N0") ₫
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-box">
                        <div class="label">
                            Voucher phổ biến nhất
                        </div>

                        <div class="value text-primary">
                            @Model.BestVoucher
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-box">
                        <div class="label">
                            Lượt sử dụng
                        </div>

                        <div class="value text-success">
                            @Model.BestVoucherUsage
                        </div>
                    </div>
                </div>

            </div>

                <div class="card shadow border-0 mt-4 w-100">

                    <div class="card-header">
                        <h4 class="mb-0 fw-bold">
                            🎟 Top Voucher được sử dụng nhiều nhất
                        </h4>
                    </div>

                    <div class="card-body">

                        <div style="height:450px;">
                            <canvas id="voucherChart"></canvas>
                        </div>

                    </div>

                </div>

            <div class="card shadow border-0 mt-4">

                <div class="card-header">
                    <h5 class="mb-0">
                        📋 Chi tiết Voucher
                    </h5>
                </div>

                <div class="card-body">

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Mã Voucher</th>
                                <th>Lượt dùng</th>
                                <th>Tổng giảm giá</th>
                                <th>Tỷ lệ</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.VoucherStatistics)
                            {
                                <tr>
                                    <td>@item.VoucherCode</td>
                                    <td>@item.UsedCount</td>
                                    <td>@item.TotalDiscount.ToString("N0") ₫</td>
                                    <td>@item.UsageRate %</td>
                                </tr>
                            }
                        </tbody>

                    </table>

                </div>

            </div>

        </div>
        </div>


    <!-- ================= JS ================= -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labelsByDate = @Html.Raw(Json.Serialize(Model.LabelsByDate));
        const revenueByDate = @Html.Raw(Json.Serialize(Model.RevenueByDate));
        const ticketCountByDate = @Html.Raw(Json.Serialize(Model.TicketCountByDate));

        const labelsByMonth = @Html.Raw(Json.Serialize(Model.LabelsByMonth));
        const revenueByMonth = @Html.Raw(Json.Serialize(Model.RevenueByMonth));
        const ticketCountByMonth = @Html.Raw(Json.Serialize(Model.TicketCountByMonth));

        const labelsByYear = @Html.Raw(Json.Serialize(Model.LabelsByYear));
        const revenueByYear = @Html.Raw(Json.Serialize(Model.RevenueByYear));
        const ticketCountByYear = @Html.Raw(Json.Serialize(Model.TicketCountByYear));

        const movieLabels = @Html.Raw(Json.Serialize(Model.MovieLabels));
        const revenueByMovie = @Html.Raw(Json.Serialize(Model.RevenueByMovie));
        const ticketData = @Html.Raw(Json.Serialize(Model.TicketsByMovie));
        const showtimeLabels =
        @Html.Raw(Json.Serialize(Model.ShowtimeLabels));

        const revenueByShowtime =
        @Html.Raw(Json.Serialize(Model.RevenueByShowtime));

        const comboPieLabels =
        @Html.Raw(Json.Serialize(Model.ComboPieLabels));

        const comboPieValues =
        @Html.Raw(Json.Serialize(Model.ComboPieValues));


        function createChart(id, labels, data1, data2) {
        new Chart(document.getElementById(id), {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [
        {
        label: 'Doanh thu',
        data: data1,
        yAxisID: 'y'
        },
        {
        label: 'Số vé',
        data: data2,
        type: 'line',
        yAxisID: 'y1'
        }
        ]
        },
        options: {
        responsive: true
        }
        });
        }

        createChart("revenueByDateChart", labelsByDate, revenueByDate, ticketCountByDate);
        createChart("revenueByMonthChart", labelsByMonth, revenueByMonth, ticketCountByMonth);
        createChart("revenueByYearChart", labelsByYear, revenueByYear, ticketCountByYear);

        new Chart(document.getElementById("revenueByMovieChart"), {
        type: 'pie',
        data: {
        labels: movieLabels,
        datasets: [{ data: revenueByMovie }]
        }
        });

        new Chart(document.getElementById("comboPieChart"), {

        type: 'pie',

        data: {

        labels: comboPieLabels,

        datasets: [{
        data: comboPieValues
        }]
        }

        });
        new Chart(
        document.getElementById("showtimeRevenueChart"),
        {
        type: 'bar',
        data: {
        labels: showtimeLabels,
        datasets: [{
        label: 'Doanh thu',
        data: revenueByShowtime,
        maxBarThickness: 60,
        borderRadius: 6
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false
        }
        }

        );

        new Chart(document.getElementById('comboPie'), {
        type: 'pie',
        data: {
        labels: @Html.Raw(Json.Serialize(Model.ComboPieLabels)),
        datasets: [{
        data: @Html.Raw(Json.Serialize(Model.ComboPieValues))
        }]
        }
        });

