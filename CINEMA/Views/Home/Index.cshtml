@model IEnumerable<CINEMA.Models.Movie>

@{
    ViewData["Title"] = "Trang chủ";

    var comingSoon = ViewBag.ComingSoon as IEnumerable<CINEMA.Models.Movie>
                     ?? Enumerable.Empty<CINEMA.Models.Movie>();

    var popup = ViewBag.Popup as CINEMA.Models.Popup;
}


<!-- 🎬 POPUP QUẢNG CÁO -->
@if (popup != null && popup.IsActive)
{
    <div class="modal fade"
         id="promoPopup"
         tabindex="-1"
         data-bs-backdrop="true"
         aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered modal-lg">

            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="position-relative">

                    <!-- nút đóng -->
                    <button type="button"
                            class="btn-close position-absolute top-0 end-0 m-3 bg-white p-2 rounded-circle shadow"
                            data-bs-dismiss="modal">
                    </button>

                    <!-- ảnh banner -->
                    <img src="@popup.ImageUrl"
                         class="img-fluid w-100"
                         style="max-height:320px; object-fit:cover;" />

                </div>

                <div class="modal-body text-center p-4">

                    <h3 class="fw-bold text-danger mb-3">
                        @popup.Title
                    </h3>

                    <p class="text-muted mb-4">
                        @popup.Description
                    </p>

                    <a href="@popup.ButtonLink"
                           class="btn btn-danger btn-lg fw-bold px-5 shadow-sm popup-btn">
                        🎟 Xem ngay
                    </a>

                </div>

            </div>

        </div>

    </div>
}

<!-- 🏠 Banner -->
<div class="container mt-2">

    <h2 class="text-center mb-2  fw-bold text-gradient">
        🎬 CINEZONE - ĐIỂM HẸN ĐIỆN ẢNH CỦA BẠN 🎬
    </h2>
    <!-- 🔍 TÌM KIẾM PHIM -->
<div class="container mt-4 d-flex justify-content-center">
    <div class="search-box shadow-lg">

        <form asp-controller="Home" asp-action="Search" method="get">
            <div class="position-relative">

                <!-- Icon -->
                <i class="bi bi-search search-icon"></i>

                <!-- Input -->
                <input type="text"
                       name="keyword"
                       class="form-control search-input"
                       placeholder="Tìm phim đang chiếu..."
                       required />

                <!-- Button -->
                <button type="submit" class="btn search-btn">
                    Tìm
                </button>

            </div>
        </form>

    </div>
</div>

<style>
    .search-box {
        width: 100%;
        max-width: 1200px; /* gần bằng banner */
        background: rgba(255,255,255,0.95);
        border-radius: 50px;
        padding: 10px 15px;
        box-shadow: 0 10px 25px 
        rgba(0,0,0,0.1);
        margin: 15px auto 30px auto;
    }

    .search-input {
        border-radius: 50px;
        padding-left: 40px;
        padding-right: 90px;
        height: 45px;
        border: 1px solid #ddd;
        transition: 0.3s;
    }

    .search-input:focus {
        border-color: #dc3545;
        box-shadow: 0 0 8px rgba(220,53,69,0.3);
    }

    .search-icon {
        position: absolute;
        top: 50%;
        left: 15px;
        transform: translateY(-50%);
        color: #888;
    }

    .search-btn {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        border-radius: 50px;
        padding: 6px 20px;
        background: #dc3545;
        color: white;
        font-weight: bold;
        border: none;
        transition: 0.3s;
    }

    .search-btn:hover {
        background: #c82333;
    }

            .theater-list {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

            .theater-card {
                background: #fff;
                border-radius: 20px;
                padding: 20px;
                cursor: pointer;
                transition: .3s;
                border-left: 5px solid #dc3545;
                box-shadow: 0 5px 20px rgba(0,0,0,.08);
            }

                .theater-card:hover {
                    transform: translateX(8px);
                    background: #fff5f5;
                }

                .theater-card h5 {
                    font-weight: 700;
                    margin-bottom: 10px;
                }

                .theater-card p {
                    margin-bottom: 8px;
                    color: #555;
                }

            .map-wrapper {
                border-radius: 20px;
                overflow: hidden;
            }

            #theaterMap {
                width: 100%;
                height: 550px;
            }

            .theater-card.active {
                background: linear-gradient(135deg,#4facfe,#00f2fe);
                color: white;
                border-left: 5px solid #0d6efd;
            }
</style>
  
<div id="bannerCarousel"
         class="carousel slide carousel-fade shadow-sm rounded"
         data-bs-ride="carousel">

        <div class="carousel-inner rounded">

            <div class="carousel-item active">
                <img src="~/images/banner_web_4_.jpg"
                     class="d-block w-100 rounded">
                </div>

                <div class="carousel-item">
                    <img src="~/images/1920X560.png"
                         class="d-block w-100 rounded">
                    </div>

                    <div class="carousel-item">
                        <img src="~/images/6f0dfc9c-5711-478b-a9c1-08f0aad4feeb.jpg"
                             class="d-block w-100 rounded">
                        </div>

                    </div>

                    <button class="carousel-control-prev"
                            type="button"
                            data-bs-target="#bannerCarousel"
                            data-bs-slide="prev">

                        <span class="carousel-control-prev-icon"></span>

                    </button>

                    <button class="carousel-control-next"
                            type="button"
                            data-bs-target="#bannerCarousel"
                            data-bs-slide="next">

                        <span class="carousel-control-next-icon"></span>

                    </button>

                </div>

            </div>


            <!-- 🎟 ĐẶT VÉ NHANH -->
            <div class="container mt-4">

                <div class="card shadow-sm border-0">

                    <div class="card-body">

                        <h5 class="fw-bold mb-3">
                            🎟 ĐẶT VÉ NHANH
                        </h5>

                        <form asp-controller="Home"
                              asp-action="BookTicket"
                              method="post"
                              class="row g-3 align-items-center">

                            <div class="col-md-3">

                                <select class="form-select"
                                        id="theaterSelect"
                                        name="theaterId"
                                        required>

                                    <option selected disabled>
                                        -- Chọn rạp --
                                    </option>

                                    @foreach (var theater in ViewBag.Theaters)
                                    {
                                        <option value="@theater.TheaterId">
                                            @theater.Name
                                        </option>
                                    }

                                </select>

                            </div>

                            <div class="col-md-3">

                                <select class="form-select"
                                        id="movieSelect"
                                        name="movieId"
                                        required>

                                    <option selected disabled>
                                        -- Chọn phim --
                                    </option>

                                </select>

                            </div>

                            <div class="col-md-3">

                                <select class="form-select"
                                        id="dateSelect"
                                        name="date"
                                        required>

                                    <option selected disabled>
                                        -- Chọn ngày --
                                    </option>

                                </select>

                            </div>

                            <div class="col-md-2">

                                <select class="form-select"
                                        id="showtimeSelect"
                                        name="showtimeId"
                                        required>

                                    <option selected disabled>
                                        -- Chọn suất chiếu --
                                    </option>

                                </select>

                            </div>

                            <div class="col-md-1">

                                <button type="submit"
                                        class="btn btn-danger w-100 fw-bold">

                                    ĐẶT

                                </button>

                            </div>

                        </form>

                    </div>

                </div>

            </div>


            <!-- 🎥 PHIM ĐANG CHIẾU -->
            <section class="container my-5">

                <h2 class="fw-bold text-center mb-5 text-gradient">
                    🎬 PHIM ĐANG CHIẾU
                </h2>

                <div class="row g-4">

                    @foreach (var movie in Model.Where(m =>
                            m.ReleaseDate.HasValue &&
                            m.ReleaseDate.Value.ToDateTime(TimeOnly.MinValue) <= DateTime.Today))
                    {

                        <div class="col-md-3 col-sm-6">

                            <div class="movie-card shadow-sm border-0 h-100">

                                <div class="position-relative">

                                    <img src="@movie.PosterUrl"
                                         class="card-img-top rounded-top-4"
                                         alt="@movie.Title">

                                    <div class="overlay d-flex align-items-center justify-content-center">

                                        <a asp-controller="Home"
                                               asp-action="BookTicket"
                                               asp-route-id="@movie.MovieId"
                                               class="btn btn-warning fw-bold rounded-pill px-4 py-2 shadow">

                                            🎟 Đặt vé

                                        </a>

                                    </div>

                                </div>

                                <div class="card-body text-center">

                                    <h5 class="fw-bold">
                                        @movie.Title
                                    </h5>

                                    <p class="text-muted small">
                                        @movie.AgeRating | @movie.Duration phút
                                    </p>

                                </div>

                            </div>

                        </div>

                    }

                </div>

            </section>


            <!-- 🚀 PHIM SẮP CHIẾU -->
            <section class="container my-5">

                <h2 class="fw-bold text-center mb-5 text-gradient">
                    🚀 PHIM SẮP CHIẾU
                </h2>

                <div class="row g-4">

                    @foreach (var movie in comingSoon)
                    {

                        <div class="col-md-3 col-sm-6">

                            <div class="movie-card shadow-sm border-0 h-100">

                                <div class="position-relative">

                                    <img src="@movie.PosterUrl"
                                         class="card-img-top rounded-top-4">

                                    <div class="overlay d-flex align-items-center justify-content-center">

                                        <a class="btn btn-outline-secondary fw-bold rounded-pill px-4 py-2 shadow">
                                            ⏳ Sắp chiếu
                                        </a>

                                    </div>

                                </div>

                                <div class="card-body text-center">

                                    <h5 class="fw-bold">
                                        @movie.Title
                                    </h5>

                                    <p class="text-muted small">
                                        Khởi chiếu:
                                        @movie.ReleaseDate?.ToString("dd/MM/yyyy")
                                    </p>

                                </div>

                            </div>

                        </div>

                    }

                </div>

            </section>


            <link rel="stylesheet" href="~/css/site-home.css" />

<section class="container my-5">

    <h2 class="fw-bold text-center mb-3 text-gradient">
        📍 HỆ THỐNG RẠP CINEZONE
    </h2>

    <p class="text-center text-muted mb-5">
        Chọn rạp để xem vị trí trên bản đồ
    </p>

    <div class="row g-4">

        <!-- Danh sách rạp -->
        <div class="col-lg-4">

            <div class="theater-list">

                @foreach (var theater in ViewBag.Theaters)
                {
                    <div class="theater-card"
                         onclick="changeMap('@theater.Address',this)">

                        <h5>
                            🎬 @theater.Name
                        </h5>

                        <p>
                            📍 @theater.Address
                        </p>

                        <small>
                            ☎ @theater.Phone
                        </small>

                    </div>
                }

            </div>

        </div>

        <!-- Bản đồ -->
        <div class="col-lg-8">

            <div class="map-wrapper shadow">

                @{
                    var theaters = ViewBag.Theaters as List<CINEMA.Models.Theater>;
                    var firstTheater = theaters?.FirstOrDefault();

                    string defaultMap =
                        firstTheater != null
                        ? $"https://maps.google.com/maps?q={Uri.EscapeDataString(firstTheater.Address ?? "")}&output=embed"
                        : "https://maps.google.com/maps?q=Ho%20Chi%20Minh&output=embed";
                }

                <iframe id="theaterMap"
                        src="@defaultMap"
                        width="100%"
                        height="650"
                        style="border:0;"
                        loading="lazy">
                </iframe>
            </div>

        </div>

    </div>

</section>
            @section Scripts {
       


                <script>
                                    
                                        
                    document.addEventListener("DOMContentLoaded", function () {
                        document.addEventListener("DOMContentLoaded", function () {

    const firstCard =
        document.querySelector(".theater-card");

    if(firstCard)
        firstCard.classList.add("active");

});

                    const popupElement = document.getElementById("promoPopup");
                    if (!popupElement) return;

                    const popup = new bootstrap.Modal(popupElement);

                    // Nếu chưa hiện popup trong session
                    if (!sessionStorage.getItem("popupShown")) {

                    setTimeout(() => {
                    popup.show();
                    }, 1000);

                    sessionStorage.setItem("popupShown", "true");
                    }

                    });
                    const theaterSelect = document.getElementById("theaterSelect");
                    const movieSelect = document.getElementById("movieSelect");
                    const dateSelect = document.getElementById("dateSelect");
                    const showtimeSelect = document.getElementById("showtimeSelect");

                    theaterSelect.addEventListener("change", function () {

                        const theaterId = this.value;

                        movieSelect.innerHTML = '<option selected disabled>-- Chọn phim --</option>';
                        dateSelect.innerHTML = '<option selected disabled>-- Chọn ngày --</option>';
                        showtimeSelect.innerHTML = '<option selected disabled>-- Chọn suất chiếu --</option>';

                        fetch(`/Home/GetMoviesByTheater?theaterId=${theaterId}`)
                            .then(res => res.json())
                            .then(data => {

                                data.forEach(m => {

                                    const opt = document.createElement("option");
                                    opt.value = m.movieId;
                                    opt.textContent = m.title;

                                    movieSelect.appendChild(opt);

                                });

                            });

                    });


                    movieSelect.addEventListener("change", function () {

                        const theaterId = theaterSelect.value;
                        const movieId = this.value;

                        dateSelect.innerHTML = '<option selected disabled>-- Chọn ngày --</option>';

                        fetch(`/Home/GetShowtimes?theaterId=${theaterId}&movieId=${movieId}`)
                            .then(res => res.json())
                            .then(data => {

                                const dates = [...new Set(data.map(s => s.date))];

                                dates.forEach(d => {

                                    const opt = document.createElement("option");
                                    opt.value = d;

                                    const [y, m, day] = d.split("-");
                                    opt.textContent = `${day}/${m}/${y}`;

                                    dateSelect.appendChild(opt);

                                });

                                dateSelect.onchange = function () {

                                    const selectedDate = this.value;

                                    showtimeSelect.innerHTML = '<option selected disabled>-- Chọn suất chiếu --</option>';

                                    data.filter(s => s.date === selectedDate)
                                        .forEach(s => {

                                            const opt = document.createElement("option");

                                            opt.value = s.showtimeId;
                                            opt.textContent = `${s.time} - ${Number(s.price).toLocaleString("vi-VN")}đ`;

                                            showtimeSelect.appendChild(opt);

                                        });

                                };

                            });

                    });
                 window.changeMap = function(address, element)
{
    document
        .querySelectorAll('.theater-card')
        .forEach(x => x.classList.remove('active'));

    if(element)
        element.classList.add('active');

    const mapUrl =
        "https://maps.google.com/maps?q="
        + encodeURIComponent(address)
        + "&output=embed";

    document.getElementById("theaterMap").src = mapUrl;
}

                </script>

            }
