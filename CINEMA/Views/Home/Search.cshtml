@model IEnumerable<CINEMA.Models.Movie>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}

<style>
    .search-banner {
        background: linear-gradient(135deg,#BCD2EE,#97FFFF);
        color: black;
        padding: 30px;
        border-radius: 20px;
        margin-bottom: 35px;
        box-shadow: 0 10px 30px rgba(0,0,0,.15);
        font-size: 15px;
    }

        .search-banner h2 {
            font-weight: 700;
            margin-bottom: 10px;
        }

    .movie-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: all .3s ease;
        height: 100%;
    }

        .movie-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,.18);
        }

    .movie-poster {
        height: 380px;
        object-fit: cover;
        transition: .4s;
    }

    .movie-card:hover .movie-poster {
        transform: scale(1.05);
    }

    .movie-title {
        font-size: 18px;
        font-weight: 700;
        min-height: 55px;
        color: #222;
    }

    .book-btn {
        border-radius: 50px;
        padding: 10px 24px;
        font-weight: 600;
    }

    .empty-state {
        text-align: center;
        background: #fff;
        border-radius: 20px;
        padding: 60px 20px;
        margin-bottom: 40px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
    }

    .empty-icon {
        font-size: 80px;
    }

    .suggest-title {
        font-weight: 700;
        color: #ff9800;
        margin-bottom: 25px;
    }

    .movie-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 10;
        font-size: 12px;
    }

    .poster-wrapper {
        position: relative;
        overflow: hidden;
    }

    .result-count {
        font-size: 24px;
        font-weight: 600;
        color: black;
        margin-bottom: 10px;
    }

    .result-total {
        font-size: 22px;
        font-weight: 700;
        color: #0d6efd;
    }
</style>

<div class="container mt-4 mb-5">

    <div class="search-banner">
        <h2>KẾT QUẢ TÌM KIẾM</h2>

        <p class="result-count">
            Từ khóa:
            <strong>"@ViewBag.Keyword"</strong>
        </p>

        @if (Model.Any())
        {
            <p class="mb-0 mt-2">
                Tìm thấy <strong>@Model.Count()</strong> phim phù hợp
            </p>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">

            <div class="empty-icon">
                🎬
            </div>

            <h3 class="mt-3">
                Không tìm thấy phim phù hợp
            </h3>

            <p class="text-muted mt-2">
                Hãy thử từ khóa khác hoặc khám phá những bộ phim đang được yêu thích.
            </p>

        </div>

        var suggestions = ViewBag.SuggestMovies as List<CINEMA.Models.Movie>;

        @if (suggestions != null && suggestions.Any())
        {
            <h3 class="suggest-title">
                🔥 Có thể bạn sẽ thích
            </h3>

            <div class="row">
                @foreach (var movie in suggestions)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                        <div class="card movie-card">

                            <div class="poster-wrapper">

                                <span class="badge bg-success movie-badge">
                                    Đang chiếu
                                </span>

                                <img src="@movie.PosterUrl"
                                     class="card-img-top movie-poster"
                                     alt="@movie.Title" />

                            </div>

                            <div class="card-body text-center">

                                <div class="movie-title">
                                    @movie.Title
                                </div>

                                <a asp-action="BookTicket"
                                   asp-route-id="@movie.MovieId"
                                   class="btn btn-warning book-btn mt-3">
                                    🎟 Đặt vé ngay
                                </a>

                            </div>

                        </div>

                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="row">

            @foreach (var movie in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                    <div class="card movie-card">

                        <div class="poster-wrapper">

                            <span class="badge bg-success movie-badge">
                                Đang chiếu
                            </span>

                            <img src="@movie.PosterUrl"
                                 class="card-img-top movie-poster"
                                 alt="@movie.Title" />

                        </div>

                        <div class="card-body text-center">

                            <div class="movie-title">
                                @movie.Title
                            </div>

                            <a asp-action="BookTicket"
                               asp-route-id="@movie.MovieId"
                               class="btn btn-warning book-btn mt-3">
                                🎟 Đặt vé ngay
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>
