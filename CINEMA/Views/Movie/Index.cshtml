@model IEnumerable<CINEMA.Models.Movie>
@{
    ViewData["Title"] = "Quản lý phim";
    Layout = "_AdminLayout";

    var today = DateTime.Today;

    var nowShowing = Model?
        .Where(m => m.IsActive == true && m.ReleaseDate.HasValue &&
               m.ReleaseDate.Value.ToDateTime(TimeOnly.MinValue) <= today)
        .ToList() ?? new();

    var comingSoon = Model?
        .Where(m => m.ReleaseDate.HasValue &&
               m.ReleaseDate.Value.ToDateTime(TimeOnly.MinValue) > today)
        .ToList() ?? new();

    var stopped = Model?
        .Where(m => m.IsActive == false)
        .ToList() ?? new();
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">🎬 Quản lý phim</h2>
            <small class="text-muted">Quản lý toàn bộ phim</small>
        </div>

        <a asp-action="Create" class="btn btn-success shadow-sm px-4">
            <i class="bi bi-plus-circle me-2"></i> Thêm phim
        </a>
    </div>

    <!-- STATS -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 p-3">
                <h5 class="text-success">@nowShowing.Count</h5>
                <small class="text-muted">Đang chiếu</small>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 p-3">
                <h5 class="text-warning">@comingSoon.Count</h5>
                <small class="text-muted">Sắp chiếu</small>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 p-3">
                <h5 class="text-danger">@stopped.Count</h5>
                <small class="text-muted">Ngừng chiếu</small>
            </div>
        </div>
    </div>

    <!-- TOAST -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-4" style="z-index:9999;">
            <div id="successToast" class="toast show text-bg-success border-0 shadow-lg rounded-4">
                <div class="d-flex align-items-center p-3">
                    <i class="bi bi-check-circle-fill fs-4 me-2"></i>
                    <div class="fw-semibold">
                        @TempData["SuccessMessage"]
                    </div>
                    <button class="btn-close btn-close-white ms-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        </div>
    }

    <!-- ================= PHIM ĐANG CHIẾU ================= -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-success text-white fw-semibold d-flex justify-content-between">
            🎬 Phim đang chiếu
            <span class="badge bg-light text-dark">@nowShowing.Count</span>
        </div>

        <div class="card-body p-0">
            @if (nowShowing.Count == 0)
            {
                <div class="text-center py-4 text-muted">Không có dữ liệu</div>
            }
            else
            {
                @Html.Partial("_MovieTable", nowShowing)
            }
        </div>
    </div>

    <!-- ================= PHIM SẮP CHIẾU ================= -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-warning text-dark fw-semibold d-flex justify-content-between">
            🚀 Phim sắp chiếu
            <span class="badge bg-light text-dark">@comingSoon.Count</span>
        </div>

        <div class="card-body p-0">
            @if (comingSoon.Count == 0)
            {
                <div class="text-center py-4 text-muted">Không có dữ liệu</div>
            }
            else
            {
                @Html.Partial("_MovieTableComingSoon", comingSoon)
            }
        </div>
    </div>

    <!-- ================= PHIM NGỪNG CHIẾU ================= -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-danger text-white fw-semibold d-flex justify-content-between">
            🛑 Phim ngừng chiếu
            <span class="badge bg-light text-dark">@stopped.Count</span>
        </div>

        <div class="card-body p-0">
            @if (stopped.Count == 0)
            {
                <div class="text-center py-4 text-muted">Không có dữ liệu</div>
            }
            else
            {
                @Html.Partial("_MovieTableStopped", stopped)
            }
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toast = document.getElementById("successToast");
            if (toast) {
                setTimeout(() => {
                    toast.style.opacity = "0";
                    toast.style.transform = "translateX(50px)";
                    setTimeout(() => toast.remove(), 400);
                }, 5000);
            }
        });
    </script>
}