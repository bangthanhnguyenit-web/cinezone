@using Microsoft.AspNetCore.Http

<!DOCTYPE html>

<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineZone Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    @RenderSection("Styles", required: false)

    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                background: #f5f7fb;
                font-family: 'Segoe UI', sans-serif;
            }

            .admin-wrapper {
                display: flex;
                min-height: 100vh;
            }

            /* SIDEBAR */
            .sidebar {
                width: 280px;
                background: #111827;
                color: white;
                position: fixed;
                left: 0;
                top: 0;
                bottom: 0;
                overflow-y: auto;
                z-index: 1000;
            }

            .logo {
                padding: 25px;
                text-align: center;
                font-size: 26px;
                font-weight: 700;
                border-bottom: 1px solid rgba(255,255,255,.08);
            }

                .logo .red {
                    color: #ef4444;
                }

            .admin-info {
                text-align: center;
                padding: 25px 15px;
                border-bottom: 1px solid rgba(255,255,255,.08);
            }

            .avatar {
                width: 75px;
                height: 75px;
                border-radius: 50%;
                background: #374151;
                display: flex;
                justify-content: center;
                align-items: center;
                margin: auto;
                font-size: 35px;
                margin-bottom: 10px;
            }

            .admin-name {
                font-size: 16px;
                font-weight: 600;
            }

            .admin-role {
                color: #9ca3af;
                font-size: 13px;
            }

            .sidebar-menu {
                list-style: none;
                padding: 15px 10px;
            }

                .sidebar-menu li {
                    margin-bottom: 5px;
                }

                .sidebar-menu a {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    text-decoration: none;
                    color: #d1d5db;
                    padding: 12px 15px;
                    border-radius: 10px;
                    transition: .3s;
                    font-size: 15px;
                    font-weight: 500;
                }

                    .sidebar-menu a:hover {
                        background: #10b981;
                        color: white;
                    }

                    .sidebar-menu a i {
                        font-size: 18px;
                    }

                    .sidebar-menu a.active {
                        background: #10b981;
                        color: #fff;
                        font-weight: 600;
                    }

                        .sidebar-menu a.active i {
                            color: #fff;
                        }

            /* CONTENT */
            .main-content {
                flex: 1;
                margin-left: 280px;
                padding: 25px;
            }

            .content-box {
                background: white;
                border-radius: 16px;
                padding: 25px;
                min-height: calc(100vh - 50px);
                box-shadow: 0 3px 15px rgba(0,0,0,.08);
            }

            /* FOOTER */
            .footer {
                margin-top: 20px;
                text-align: center;
                color: #6b7280;
                font-size: 14px;
            }

            /* SCROLLBAR */
            .sidebar::-webkit-scrollbar {
                width: 6px;
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: #4b5563;
                border-radius: 10px;
            }

            /* MOBILE */
            @@media (max-width: 992px) {

                .sidebar {
                    position: relative;
                    width: 100%;
                    height: auto;
                }

                .main-content {
                    margin-left: 0;
                }

                .admin-wrapper {
                    flex-direction: column;
                }
            }
            /* Sidebar thu nhỏ */
            .sidebar.collapsed {
                width: 80px;
            }

                .sidebar.collapsed .logo-text,
                .sidebar.collapsed .admin-info,
                .sidebar.collapsed .sidebar-menu span {
                    display: none;
                }

                .sidebar.collapsed .sidebar-menu a {
                    justify-content: center;
                }

                    .sidebar.collapsed .sidebar-menu a i {
                        margin: 0;
                        font-size: 22px;
                    }

            .main-content {
                margin-left: 280px;
                transition: all .3s ease;
            }

                .main-content.expanded {
                    margin-left: 80px;
                }

            /* Toggle button */
            .toggle-btn {
                background: transparent;
                border: none;
                color: white;
                font-size: 24px;
                cursor: pointer;
            }

            .logo {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px;
            }
    </style>
</head>

<body>
    <div class="admin-wrapper">

        <!-- Sidebar -->
        <aside class="sidebar">

            <div class="logo">

                <span class="logo-text">
                    CINEZONE
                </span>

                <button id="toggleSidebar" class="toggle-btn">
                    <i class="bi bi-list"></i>
                </button>

            </div>

            <div class="admin-info">

                <div class="avatar">
                    <i class="bi bi-person-fill"></i>
                </div>

                <div class="admin-name">
                    @Context.Session.GetString("Name")
                </div>

                <div class="admin-role">
                    Administrator
                </div>

            </div>

            <ul class="sidebar-menu">

                <li>
                    <a asp-controller="Admin" asp-action="Dashboard"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="Theater" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Theater" ? "active" : "")">
                        <i class="bi bi-building"></i>
                        <span>Quản lý Rạp</span>
                    </a>
                </li>   
                        
                <li>                   
                    <a asp-controller="Auditorium" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Auditorium" ? "active" : "")">
                        <i class="bi bi-easel"></i>
                        <span>  Quản lý Phòng Chiếu</span>
                    </a>
                </li>   
                        
                <li>    
                    <a asp-controller="Movie" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Movie" ? "active" : "")">
                        <i class="bi bi-film"></i>
                        <span>Quản lý Phim</span>
                    </a>
                </li>   
                        
                <li>    
                    <a asp-controller="Showtime" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Showtime" ? "active" : "")">
                        <i class="bi bi-calendar-event"></i>
                        <span>Quản lý Lịch Chiếu</span>
                    </a>
                </li>   
                        
                <li>    
                    <a asp-controller="Genre" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Genre" ? "active" : "")">
                        <i class="bi bi-tags"></i>
                        <span> Quản lý Thể Loại</span>
                    </a>
                </li>   
                        
                <li>    
                    <a asp-controller="Combo" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Combo" ? "active" : "")">
                        <i class="bi bi-cup-straw"></i>
                        <span>  Quản lý Combo</span>
                    </a>
                </li>   
                        
                <li>    
                    <a asp-controller="CustomerAdmin" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "CustomerAdmin" ? "active" : "")">
                        <i class="bi bi-people"></i>
                        <span>Quản lý Khách Hàng</span>
                    </a>
                </li>   
                        
                <li>    
                    <a asp-controller="AdminOrders" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminOrders" ? "active" : "")">
                        <i class="bi bi-bag-check"></i>
                        <span>Quản lý Đơn Hàng</span>
                    </a>
                </li>   
                        
                <li>                     
                    <a asp-controller="AdminVoucher" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminVoucher" ? "active" : "")">
                        <i class="bi bi-ticket-perforated"></i>
                        <span> Quản lý Voucher</span>
                    </a>
                </li>   
                        
                <li>                    
                    <a asp-controller="AdminPopup" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminPopup" ? "active" : "")">
                        <i class="bi bi-megaphone"></i>
                        <span>Quản lý Popup</span>
                    </a>
                </li>   
                        
                <li>
                    <a asp-controller="Statistics" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Statistics" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="bi bi-bar-chart-line"></i>
                        <span>Báo Cáo Doanh Thu</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="Statistics" asp-action="AdvancedStats"
                       class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Statistics" && ViewContext.RouteData.Values["Action"]?.ToString() == "AdvancedStats" ? "active" : "")">
                        <i class="bi bi-pie-chart"></i>
                        <span>Báo cáo thống kê</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="Admin" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Đăng Xuất</span>
                    </a>
                </li>

            </ul>

        </aside>

        <!-- Main Content -->
        <main class="main-content">

            <div class="content-box">
                @RenderBody()
            </div>

            <div class="footer">
                © 2026 CineZone Admin System. All Rights Reserved.
            </div>

        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        const sidebar = document.querySelector('.sidebar');
        const content = document.querySelector('.main-content');
        const toggleBtn = document.getElementById('toggleSidebar');

        toggleBtn.addEventListener('click', () => {

        sidebar.classList.toggle('collapsed');
        content.classList.toggle('expanded');

        const icon = toggleBtn.querySelector('i');

        if (sidebar.classList.contains('collapsed')) {
        icon.className = 'bi bi-layout-sidebar';
        } else {
        icon.className = 'bi bi-list';
        }
        });
    </script>
</body>
</html>
