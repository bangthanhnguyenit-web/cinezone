<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CINEZONE</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CINEMA.styles.css" asp-append-version="true" />

</head>

<body>

    <!-- HEADER -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow fixed-top">
            <div class="container">

                <!-- Logo -->
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <img src="/images/unnamed.jpg" class="footer-logo" />
                    CineZone
                </a>

                <!-- Toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menu -->
                <div class="collapse navbar-collapse" id="navbarContent">

                    <!-- Left -->
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> Trang chủ
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Schedule">
                                <i class="bi bi-calendar-event"></i> Lịch chiếu
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-primary" href="#" data-bs-toggle="modal" data-bs-target="#modalMembershipSummary">
                                <i class="bi bi-gem"></i> Thành viên
                            </a>
                        </li>
                    </ul>

                    <!-- Right -->
                    <ul class="navbar-nav ms-auto">

                        @if (Context.Session.GetString("CustomerName") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="Register">
                                    <i class="bi bi-person-plus"></i> Đăng ký
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle"
                                       data-bs-toggle="dropdown">

                                    <i class="bi bi-person-circle"></i>
                                    Xin chào, @Context.Session.GetString("CustomerName")
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end">

                                    <li>
                                        <a class="dropdown-item"
                                               asp-controller="Customer"
                                               asp-action="Profile">

                                            Hồ sơ cá nhân
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                               asp-controller="Tickets"
                                               asp-action="MyTickets">

                                            Vé của tôi
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider"></li>

                                    <li>
                                        <a class="dropdown-item text-danger"
                                               asp-controller="Customer"
                                               asp-action="Logout">

                                            Đăng xuất
                                        </a>
                                    </li>

                                </ul>

                            </li>
                        }

                    </ul>

                </div>

            </div>
        </nav>
    </header>


    <!-- MAIN -->
    <main class="container py-4" style="margin-top:10px;">
        @RenderBody()
    </main>
    <!-- FOOTER -->
    <footer class="text-white mt-5 pt-5 pb-4"
            style="background: linear-gradient(90deg,#CBE7E3,#3b82f6);">

        <div class="container">

            <div class="row gy-4">

                <div class="col-lg-3">

                    <img src="/images/unnamed.jpg" class="footer-logo" />

                    <p class="small mt-2">Điểm hẹn điện ảnh</p>

                    <a asp-controller="Home"
                           asp-action="Schedule"
                           class="btn btn-warning fw-bold">

                        🎟 ĐẶT VÉ
                    </a>

                </div>

                <div class="col-lg-2">
                    <h6>Tài khoản</h6>

                    <a asp-controller="Customer"
                           asp-action="Login"
                           class="text-white d-block">

                        Đăng nhập
                    </a>

                    <a asp-controller="Customer"
                           asp-action="Register"
                           class="text-white d-block">

                        Đăng ký
                    </a>
                </div>

                <div class="col-lg-2">
                    <h6>Xem phim</h6>

                    <a asp-controller="Home"
                           asp-action="Index"
                           class="text-white d-block">

                        Phim đang chiếu
                    </a>

                    <a asp-controller="Home"
                           asp-action="Index"
                           class="text-white d-block">

                        Phim sắp chiếu
                    </a>

                </div>

                <div class="col-lg-2">
                    <h6>Dịch vụ</h6>

                    <a href="#" class="text-white d-block">
                        Thuê rạp
                    </a>
                </div>

                <div class="col-lg-3">
                    <h6>Hệ thống rạp</h6>

                    <a href="#" class="text-white d-block">
                        CineZone Quận 1
                    </a>
                </div>

            </div>

            <hr>

            <div class="d-flex justify-content-between small">

                <div>
                    © 2025 <strong>CineZone</strong>
                </div>

                <div>
                    <a asp-controller="Home"
                           asp-action="Privacy"
                           class="text-white me-3">

                        Chính sách bảo mật
                    </a>

                    <a href="#" class="text-white">
                        Hỏi & Đáp
                    </a>
                </div>

            </div>

        </div>

    </footer>



    @* <!-- POPUP -->
    @{
        var popup = ViewBag.Popup as CINEMA.Models.Popup;
    }

    @if (popup != null && popup.IsActive)
    {
        <div id="promoPopup" class="promo-popup">

            <div class="promo-content">

                
                <button class="close-popup" id="closePopup">&times;</button>                <img src="@popup.ImageUrl"
                     style="width:100%;border-radius:10px;" />

                <h4 class="text-center mt-3">
                    @popup.Title
                </h4>

                <p class="text-center">
                    @popup.Description
                </p>

                <div class="text-center">
                    <a href="@popup.ButtonLink"
                           class="btn btn-danger">

                        Xem ngay
                    </a>
                </div>

            </div>

        </div>
    } *@
    <!-- CHAT BUTTON -->
    <div id="chat-toggle">💬</div>

   <div id="chatbox">
    <div id="chat-header">
        🎬 Hỗ trợ đặt vé
        <span onclick="toggleChat()">✖</span>
    </div>

    <div id="chat-body">

        <!-- BOT -->
        <div class="message bot">
            <div class="avatar">🤖</div>
            <div class="bubble">Xin chào! Bạn cần gì?</div>
        </div>

        <!-- GỢI Ý -->
        <div class="suggestions">
            <button onclick="quickAsk('phim đang chiếu')">🎬 Phim đang chiếu</button>
            <button onclick="quickAsk('lịch chiếu')">⏰ Lịch chiếu</button>
            <button onclick="quickAsk('ghế trống')">💺 Ghế trống</button>
        </div>

    </div>

    <div class="chat-input">
        <input id="chatInput" placeholder="Nhập câu hỏi..." />
        <button onclick="sendMessage()">➤</button>
    </div>
</div>


    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>

            document.addEventListener("DOMContentLoaded", function () {

                const popup = document.getElementById("promoPopup");
                const closeBtn = document.getElementById("closePopup");

                if (!popup) return;

                // đóng bằng nút X
                if (closeBtn) {
                    closeBtn.addEventListener("click", function (e) {
                        e.stopPropagation();
                        popup.style.display = "none";
                    });
                }

                // đóng khi bấm ra ngoài
                popup.addEventListener("click", function (e) {
                    if (e.target === popup) {
                        popup.style.display = "none";
                    }
                });

            });

    </script>

</body>
</html>





<style>
    .footer-logo {
        height: 80px;
        border-radius: 50%;
    }

    .navbar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .navbar-brand img {
            height: 40px;
        }
</style>









<style>
    #chat-toggle {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: linear-gradient(135deg, #198754, #28a745);
        color: white;
        font-size: 22px;
        padding: 16px;
        border-radius: 50%;
        cursor: pointer;
        z-index: 9999;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    #chatbox {
        position: fixed;
        bottom: 80px;
        right: 20px;
        width: 340px;
        height: 500px;
        background: #fff;
        border-radius: 20px;
        display: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        overflow: hidden;
    }

    #chat-header {
        background: linear-gradient(135deg, #198754, #28a745);
        color: white;
        padding: 12px;
        font-weight: bold;
        display: flex;
        justify-content: space-between;
    }

    #chat-body {
        height: 380px;
        overflow-y: auto;
        padding: 12px;
        background: #f5f6f7;
    }

    /* MESSAGE */
    .message {
        display: flex;
        margin-bottom: 10px;
    }

        .message.bot {
            align-items: flex-start;
        }

        .message.user {
            justify-content: flex-end;
        }

    .avatar {
        margin-right: 8px;
    }

    .bubble {
        padding: 10px 14px;
        border-radius: 16px;
        max-width: 70%;
        white-space: pre-line;
    }

    /* BOT */
    .bot .bubble {
        background: #e4e6eb;
    }

    /* USER */
    .user .bubble {
        background: #198754;
        color: white;
    }

    /* INPUT */
    .chat-input {
        display: flex;
        border-top: 1px solid #ddd;
    }

        .chat-input input {
            flex: 1;
            border: none;
            padding: 12px;
            outline: none;
        }

        .chat-input button {
            background: #198754;
            color: white;
            border: none;
            padding: 12px;
            cursor: pointer;
        }

    /* SUGGESTION */
    .suggestions button {
        border: none;
        background: white;
        border-radius: 20px;
        padding: 6px 12px;
        margin: 3px;
        font-size: 12px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        cursor: pointer;
    }

        .suggestions button:hover {
            background: #198754;
            color: white;
        }
    #typing .bubble {
        font-style: italic;
        opacity: 0.7;
    }

    #chatbox {
        z-index: 9999;
    }

    #chat-toggle {
        z-index: 9999;
    }
</style>
<script>
    function toggleChat() {
        let box = document.getElementById("chatbox");
        box.style.display = box.style.display === "none" ? "block" : "none";
    }

    document.getElementById("chat-toggle").onclick = toggleChat;

    // 🔥 MESSAGE ĐẸP
       function addMessage(text, type) {
        let div = document.createElement("div");
        div.className = "message " + type;

        let bubble = `<div class="bubble">${text}</div>`;

        if (type === "bot") {
            div.innerHTML = `<div class="avatar">🤖</div>` + bubble;
        } else {
            div.innerHTML = bubble;
        }

        document.getElementById("chat-body").appendChild(div);

        let body = document.getElementById("chat-body");
        body.scrollTop = body.scrollHeight;
    }
    // 🔥 GỬI TIN
       function sendMessage() {
        let input = document.getElementById("chatInput");
        let msg = input.value.trim();

        if (!msg) return;

        addMessage(msg, "user");

        // 👉 typing...
        let typing = document.createElement("div");
        typing.className = "message bot";
        typing.id = "typing";

        typing.innerHTML = `
            <div class="avatar">🤖</div>
            <div class="bubble">Đang trả lời...</div>
        `;

        document.getElementById("chat-body").appendChild(typing);

        let body = document.getElementById("chat-body");
        body.scrollTop = body.scrollHeight;

        fetch('/Chatbot/Ask', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: msg })
        })
        .then(res => res.json())
        .then(data => {

            // ❌ xóa typing
            document.getElementById("typing")?.remove();

            // ✅ hiển thị bot
            addMessage(data, "bot");
        });

        input.value = "";
    }
    // ENTER gửi luôn
    document.getElementById("chatInput").addEventListener("keypress", function(e) {
        if (e.key === "Enter") sendMessage();
    });

    // GỢI Ý
    function quickAsk(text) {
        document.getElementById("chatInput").value = text;
        sendMessage();
    }
</script>
