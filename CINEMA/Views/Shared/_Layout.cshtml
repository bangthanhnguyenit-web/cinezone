                    </div>
                </div>
                
                <div class="text-center mt-4">
                    @if (Context.Session.GetString("CustomerName") != null)
                    {
                        <a asp-controller="Customer" asp-action="Profile" class="btn btn-outline-primary rounded-pill">Xem tiến trình của tôi</a>
                    }
